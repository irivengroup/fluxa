{
  "name": "iriven/php-form-generator",
  "description": "Enterprise form framework for PHP with nested forms, collections, transformers, events and themes",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.95",
    "infection/infection": "^0.29",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^11.5",
    "rector/rector": "^1.2"
  },
  "autoload": {
    "psr-4": {
      "Iriven\\PhpFormGenerator\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Iriven\\PhpFormGenerator\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit --colors=never --display-warnings --display-deprecations",
    "test:coverage": "vendor/bin/phpunit --coverage-text --colors=never",
    "lint": "find src tests -name '*.php' -print0 | xargs -0 -n1 php -l",
    "analyse": "vendor/bin/phpstan analyse --memory-limit=1G src tests",
    "cs": "vendor/bin/php-cs-fixer fix --dry-run --diff --verbose",
    "cs:fix": "vendor/bin/php-cs-fixer fix",
    "refactor": "vendor/bin/rector process",
    "mutate": "vendor/bin/infection --threads=max --min-msi=70 --min-covered-msi=80 --skip-initial-tests"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "infection/extension-installer": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
